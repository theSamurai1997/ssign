#!/bin/bash
# ssign tier-2 validation PBS script for Imperial CX3 GPU nodes.
#
# Defaults to ssign-tutorial/ecoli_k12.gbff at the extended tier and a
# 4 h walltime — the common case. Override INPUT_GBFF for other test
# genomes; override walltime on the qsub command line when including
# pLM-BLAST (which can take 2-4 h on autotransporter-heavy genomes).
#
# Usage:
#   # Standard K-12 race across GPU types (current default):
#   qsub scripts/cx3/run_k12_validation.pbs
#
#   # Override genome:
#   qsub -v INPUT_GBFF=$HOME/ssign-tutorial/pseudomonas_pao1.gbff \
#        scripts/cx3/run_k12_validation.pbs
#
#   # Overnight run with longer walltime so pLM-BLAST finishes:
#   qsub -l walltime=16:00:00 \
#        -v INPUT_GBFF=$HOME/ssign-tutorial/salmonella_tymph.gbff \
#        scripts/cx3/run_k12_validation.pbs
#
# Pre-fix runs (before 82cece9 CPU-share fix) hit 2 h walltime kill
# under oversubscription. Post-fix the prediction half finishes in
# ~60-90 m; annotation (esp. pLM-BLAST) may take an additional 2-4 h on
# autotransporter-heavy genomes — see task #46/#4.

#PBS -l select=1:ncpus=32:mem=64gb:ngpus=1
#PBS -l walltime=16:00:00
#PBS -N ssign_validation
#PBS -j oe
#PBS -o ssign_validation.log
#PBS -S /bin/bash

set -eo pipefail

# INPUT_GBFF can be overridden via `-v INPUT_GBFF=/path/to/genome.gbff`.
# Default keeps the historical K-12 behaviour.
: "${INPUT_GBFF:=$HOME/ssign-tutorial/ecoli_k12.gbff}"
test -f "$INPUT_GBFF" || { echo "FATAL: INPUT_GBFF not found at $INPUT_GBFF"; exit 1; }

# Derive a sample tag from the genome filename so RUN_DIR doesn't clobber
# when racing different genomes in parallel.
SAMPLE_TAG="$(basename "$INPUT_GBFF" | sed 's/\.[^.]*$//')"

# GPU_TYPE is set via `-v GPU_TYPE=L40S` on the qsub command line when
# submitting multiple jobs to compare GPU types in parallel. The default
# matches the #PBS gpu_type=L40S directive above.
: "${GPU_TYPE:=L40S}"
# Include PBS_JOBID so simultaneously-released jobs in the same second
# don't collide on the same RUN_DIR and clobber each other's outputs.
RUN_DIR="$HOME/runs/${SAMPLE_TAG}_${GPU_TYPE}_$(date +%Y%m%d_%H%M%S)_${PBS_JOBID%%.*}"
VENV="$HOME/blastp_t5a/ssign/.venv"

mkdir -p "$RUN_DIR" && cd "$RUN_DIR"

echo "===== JOB START $(date -Is) | $(hostname) | $PBS_JOBID ====="
nvidia-smi || { echo "FATAL: no GPU"; exit 1; }

source ~/.bashrc 2>/dev/null || true
module load Java/11.0.25 || { echo "FATAL: Java/11.0.25 module unavailable. Check 'module avail Java'."; exit 1; }
java -version 2>&1

source "$VENV/bin/activate"
command -v ssign >/dev/null || { echo "FATAL: ssign not on PATH after venv activation. Check $VENV/bin/ssign exists."; exit 1; }
echo "  ssign -> $(command -v ssign)"

# bakta-deps conda env on PATH for tRNAscan-SE, etc.
export PATH="$PATH:$HOME/.conda/envs/bakta-deps/bin"

# pLM-BLAST script path. Set on 2026-06-03 install.
export SSIGN_PLMBLAST_SCRIPT="$HOME/tools/pLM-BLAST/scripts/plmblast.py"
test -f "$SSIGN_PLMBLAST_SCRIPT" || { echo "FATAL: SSIGN_PLMBLAST_SCRIPT not found at $SSIGN_PLMBLAST_SCRIPT"; exit 1; }

echo "----- tools -----"
for c in hmmsearch macsyfinder signalp6 deeplocpro emapper.py bakta hhblits tRNAscan-SE java; do
  if command -v "$c" >/dev/null; then
    echo "  $c -> $(command -v "$c")"
  else
    echo "  $c MISSING"
  fi
done

echo "===== ssign run START $(date -Is) ====="
# SSIGN_EXTRA_ARGS appends additional ssign flags (e.g.
# --t5ass-annotate-whole, --skip-protparam). Pass via
#   qsub -v INPUT_GBFF=...,SSIGN_EXTRA_ARGS="--t5ass-annotate-whole" ...
# Word-splits on whitespace in the variable so multiple flags work.
: "${SSIGN_EXTRA_ARGS:=}"
echo "extra args: $SSIGN_EXTRA_ARGS"
ssign run "$INPUT_GBFF" \
  --outdir "$RUN_DIR/results" \
  --tier extended \
  $SSIGN_EXTRA_ARGS \
  2>&1 | tee "$RUN_DIR/ssign.run.log"
SSIGN_RC=${PIPESTATUS[0]}
echo "===== ssign run END (rc=$SSIGN_RC) $(date -Is) ====="
exit $SSIGN_RC
