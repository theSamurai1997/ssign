/*
 * ssign — Nextflow configuration
 *
 * Default parameters, profiles, and container declarations.
 * Override any parameter via CLI: --param_name value
 */

// ─── Default Parameters ──────────────────────────────────────────────

params {
    // ── Input / Output ──
    input                        = null    // Samplesheet CSV or single genome file
    outdir                       = './results'

    // ── Phase 1: Input Processing ──
    run_bakta                    = false
    bakta_db                     = null    // Path to Bakta database (~30GB)

    // ── Phase 2: SS Detection ──
    wholeness_threshold          = 0.8     // MacSyFinder system completeness minimum
    excluded_systems             = 'Flagellum,Tad,T3SS'  // Comma-separated; T3SS on by default

    // ── Phase 3: Secreted Protein Prediction ──
    conf_threshold               = 0.8     // DeepLocPro extracellular probability minimum
    deeplocpro_path              = null    // Path to DeepLocPro install (DTU license required)
    signalp_path                 = null    // Path to SignalP 6.0 install (DTU license required)
    skip_signalp                 = false

    // ── Phase 4: Substrate Identification ──
    proximity_window             = 3       // +/- N genes per SS component
    required_fraction_correct    = 0.8     // Fraction of components correctly localized

    // ── Phase 5: Optional Annotation ──
    skip_annotation              = false   // Master skip — disables all annotation
    skip_structure               = false
    skip_foldseek                = false
    skip_blastp                  = false
    skip_hhsuite                 = true    // Off by default (requires ~23GB DBs)
    skip_plmblast                = true    // Off by default (requires ~5-10GB DB)
    skip_interproscan            = false
    skip_protparam               = false

    // Annotation modes: 'local' or 'remote'
    //   local  = runs tool locally, requires database download
    //   remote = uses web API, no local DB needed but rate-limited
    blastp_mode                  = 'remote'  // NCBI web API; local needs nr (~300GB) or swissprot (~1.5GB)
    hhsuite_mode                 = 'remote'  // MPI Toolkit API (200 jobs/hr, 2000/day); local needs Pfam-A (~3GB) + PDB70 (~20GB)
    interproscan_mode            = 'remote'  // EBI REST API (30 req/sec, 25k seq/day); local needs ~80GB
    foldseek_mode                = 'local'   // Local recommended (fast); remote available
    plmblast_mode                = 'local'   // Local only — MPI Toolkit ECOD70 is broken

    // Database paths (required when using local mode)
    blastp_db                    = null
    blastp_exclude_taxid         = null    // Taxonomy ID to exclude (e.g., query organism)
    hhsuite_pfam_db              = null    // HH-suite Pfam-A database (~3GB)
    hhsuite_pdb70_db             = null    // HH-suite PDB70 database (~20GB)
    hhsuite_uniclust_db          = null    // UniClust30 for hhblits MSA generation
    plmblast_ecod_db             = null    // ECOD70 database for pLM-BLAST (~5-10GB)
    foldseek_db                  = null    // Foldseek AF/Swiss-Prot DB (~10GB)
    interproscan_db              = null    // InterProScan data directory (~80GB)

    // Tool thresholds
    plddt_threshold              = 70      // Minimum mean pLDDT for structure acceptance
    esmfold_max_seq_len          = 800     // Max protein length for ESMFold (GPU memory)
    blastp_evalue                = 1e-5
    blastp_min_pident            = 80      // Minimum percent identity
    blastp_min_qcov              = 80      // Minimum query coverage
    foldseek_evalue              = 0.001
    foldseek_tmscore             = 0.8     // Query-normalized TM-score threshold

    // Reporting
    dpi                          = 300
    min_sankey_flow              = 2

    // Resource limits
    max_cpus                     = 16
    max_memory                   = '128.GB'
    max_time                     = '240.h'
}

// ─── Profiles ────────────────────────────────────────────────────────

profiles {
    local {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
    }
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }
    test {
        includeConfig 'conf/test.config'
    }
    test_full {
        includeConfig 'conf/test_full.config'
    }
    hpc_pbs {
        includeConfig 'conf/hpc_pbs.config'
    }
    hpc_slurm {
        includeConfig 'conf/hpc_slurm.config'
    }
}

// ─── Base Configuration ──────────────────────────────────────────────

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ─── Manifest ────────────────────────────────────────────────────────

manifest {
    name            = 'ssign'
    author          = 'Billerbeck Lab'
    homePage        = 'https://github.com/billerbeck-lab/ssign'
    description     = 'Secretion-system Identification for Gram Negatives'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.1.0'
}

// ─── Timeline / Report / Trace ───────────────────────────────────────

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
}
