#!/bin/bash
# Phase 2 actual-recall: run ssign on a batch of benchmark genomes, serially.
#
# Fixed benchmark config (must NOT drift between genomes):
#   --tier extended  -> DeepLocPro + SignalP + DeepSecE + PLM-Effector ON (the secretion
#                       predictors recall depends on). Run LOCAL (GPU): the compute nodes are
#                       offline, so the remote DTU fallback would fail mid-job.
#
# RECALL knobs default to the original (annotation OFF) panel config so prior runs stay
# reproducible. The 2026-06-16 "full" run opts in via -v:
#   WHOLE_GENOME=1 : run DeepLocPro/DeepSecE/SignalP/PLM-Effector on EVERY protein, not just the
#                    +/-3 SS neighborhood (gives the true genome-wide background rate for the
#                    enrichment-stats validation). Much heavier (ProtT5/ESM over the full proteome).
#   ENRICH=1       : --enrichment-stats (samples a null set + per-system binomial tests). The
#                    "proposed in-run stats" to compare against the whole-genome ground truth.
#   ANNOT=1        : turn ON the extended annotation tools (InterProScan, EggNOG, pLM-BLAST,
#                    ProtParam) instead of skipping them. Needs the tier-2 DBs (env block below).
#                    BLASTp + HH-suite are --tier full (NR / UniRef30) and stay OFF here.
#
# INPUT_MODE knob (Teo: run both, compare) — does Bakta re-annotation change recall vs the
# exact RefSeq path?
#   genbank (default): input = $INPUT_DIR_GB/<unit>.gbff + --use-input-annotations. ssign uses
#                      the RefSeq CDS, so its locus_tags ARE the gold-set tags and recall is
#                      measured in the same gene order as the Phase 1 ceiling. No Bakta.
#   fasta            : input = $INPUT_DIR/<unit>.fasta. ssign re-annotates with Bakta (needs
#                      BAKTA_DB); the Bakta->RefSeq bridge (task 6.3) then maps results back.
#
# Env knobs (all have defaults matching the CX3 tier-2 install):
#   BATCH_FILE  : file with one unit-id per line (required).
#   INPUT_MODE  : genbank | fasta              (default genbank)
#   INCLUDE_T3SS: 0 | 1                         (default 0 = stock exclusion; 1 = include T3SS)
#   WHOLE_GENOME: 0 | 1                         (default 0)
#   ENRICH      : 0 | 1                         (default 0)
#   ANNOT       : 0 | 1                         (default 0 = annotation skipped)
#   RUN_TAG     : output subdir tag            (default = INPUT_MODE)
#   INPUT_DIR   : FASTA inputs                 (default $HOME/bench/inputs)
#   INPUT_DIR_GB: GenBank inputs              (default $HOME/bench/inputs_gb)
#   OUT_ROOT    : output root                  (default $HOME/runs/benchmark_phase2)
#   SSIGN_DB    : flat DB root                 (default $EPHEMERAL/ssign-databases)
#   SSIGN_VENV  : ssign venv                   (default $HOME/blastp_t5a/ssign/.venv)
#   IPS_DIR     : InterProScan install dir     (default $SSIGN_DB/interproscan/interproscan-5.77-108.0)
#   ECOD70_DB   : pLM-BLAST ECOD70 dir         (default $SSIGN_DB/plm_blast/ECOD70)
#   EGGNOG_DIR  : EggNOG data dir              (default $SSIGN_DB/eggnog)
#   PLMBLAST_SCRIPT : pLM-BLAST entrypoint     (default $HOME/build/pLM-BLAST/scripts/plmblast.py)
#
# Submit the 2026-06-16 full run (T3SS on, whole-genome predictors, enrichment, tier-2 annotation):
#   qsub -l select=1:ncpus=16:mem=64gb:ngpus=1:gpu_type=RTX6000 -l walltime=72:00:00 \
#        -v BATCH_FILE=$HOME/bench/batches/batch_01.txt,INCLUDE_T3SS=1,WHOLE_GENOME=1,ENRICH=1,ANNOT=1,RUN_TAG=full_t3ss \
#        run_benchmark_batch.pbs
#
# Original panel reproduction (annotation off, neighborhood only):
#   qsub -v BATCH_FILE=$HOME/bench/batches/pilot.txt,INPUT_MODE=genbank,RUN_TAG=genbank_default run_benchmark_batch.pbs

# 16 cores / 64 GB / 1 GPU. gpu_type IS MANDATORY on gpu72 (omitting it -> "Placement set is too
# small", queues forever). Override walltime/footprint on the qsub line for the heavy full run.
#PBS -l select=1:ncpus=16:mem=64gb:ngpus=1:gpu_type=RTX6000
#PBS -l walltime=08:00:00
#PBS -N ssign_bench
#PBS -j oe
#PBS -o ssign_bench.log
#PBS -S /bin/bash

set -eo pipefail

: "${BATCH_FILE:?set BATCH_FILE to a file listing one unit-id per line}"
: "${INPUT_MODE:=genbank}"
: "${INCLUDE_T3SS:=0}"
: "${WHOLE_GENOME:=0}"
: "${ENRICH:=0}"
: "${ANNOT:=0}"
# EXCLUDED carries a space ("Flagellum Tad ..."), which cannot pass cleanly through
# `qsub -v` (PBS splits the comma-list and the space mangles it). So derive it here from
# the space-free INCLUDE_T3SS knob instead of passing EXCLUDED over -v.
if [ "$INCLUDE_T3SS" = "1" ]; then EXCLUDED="Flagellum Tad"; else EXCLUDED="Flagellum Tad T3SS"; fi
: "${RUN_TAG:=$INPUT_MODE}"
: "${INPUT_DIR:=$HOME/bench/inputs}"
: "${INPUT_DIR_GB:=$HOME/bench/inputs_gb}"
: "${OUT_ROOT:=$HOME/runs/benchmark_phase2}"
: "${SSIGN_DB:=$EPHEMERAL/ssign-databases}"
VENV="${SSIGN_VENV:-$HOME/blastp_t5a/ssign/.venv}"
: "${IPS_DIR:=$SSIGN_DB/interproscan/interproscan-5.77-108.0}"
: "${ECOD70_DB:=$SSIGN_DB/plm_blast/ECOD70}"
: "${EGGNOG_DIR:=$SSIGN_DB/eggnog}"
: "${PLMBLAST_SCRIPT:=$HOME/build/pLM-BLAST/scripts/plmblast.py}"

case "$INPUT_MODE" in
    genbank) IN_DIR="$INPUT_DIR_GB"; IN_EXT="gbff"; MODE_FLAGS=(--use-input-annotations) ;;
    fasta)   IN_DIR="$INPUT_DIR";    IN_EXT="fasta"; MODE_FLAGS=() ;;
    *) echo "FATAL: INPUT_MODE must be 'genbank' or 'fasta' (got '$INPUT_MODE')"; exit 1 ;;
esac

# Build the recall + annotation flag set from the knobs.
EXTRA_FLAGS=()
[ "$WHOLE_GENOME" = "1" ] && EXTRA_FLAGS+=(--dlp-whole-genome --dse-whole-genome --sp-whole-genome --plme-whole-genome)
[ "$ENRICH" = "1" ] && EXTRA_FLAGS+=(--enrichment-stats)
if [ "$ANNOT" = "1" ]; then
    # tier=extended already defaults these ON; pass --no-skip explicitly so the intent is on the
    # command line and a future tier-default change can't silently turn them off.
    EXTRA_FLAGS+=(--no-skip-interproscan --no-skip-eggnog --no-skip-plmblast --no-skip-protparam)
else
    EXTRA_FLAGS+=(--skip-eggnog --skip-interproscan --skip-plmblast --skip-protparam)
fi

test -f "$BATCH_FILE" || { echo "FATAL: BATCH_FILE not found: $BATCH_FILE"; exit 1; }
UNITS=()
while read -r u; do [ -n "$u" ] && UNITS+=("$u"); done < <(grep -v '^[[:space:]]*$' "$BATCH_FILE")

RUN_ROOT="$OUT_ROOT/$RUN_TAG"
mkdir -p "$RUN_ROOT" && cd "$RUN_ROOT"

echo "===== BENCHMARK BATCH START $(date -Is) | $(hostname) | $PBS_JOBID ====="
echo "  batch       : $BATCH_FILE (${#UNITS[@]} genomes)"
echo "  input mode  : $INPUT_MODE  (dir $IN_DIR)"
echo "  excluded SS : $EXCLUDED"
echo "  whole-genome: $WHOLE_GENOME | enrichment: $ENRICH | annotation: $ANNOT"
echo "  run tag     : $RUN_TAG  ->  $RUN_ROOT"
echo "  DB root     : $SSIGN_DB"
echo

nvidia-smi || { echo "FATAL: no GPU"; exit 1; }

source ~/.bashrc 2>/dev/null || true
module load Java/21.0.8 2>/dev/null || module load Java/11.0.25 2>/dev/null || true   # InterProScan needs Java
source "$VENV/bin/activate"
command -v ssign >/dev/null || { echo "FATAL: ssign not on PATH after venv activation."; exit 1; }
echo "  ssign -> $(command -v ssign)"

# bakta-deps conda env on PATH (Bakta sub-tools: tRNAscan-SE, aragorn, PilerCR, AMRFinder).
export PATH="$PATH:$HOME/.conda/envs/bakta-deps/bin"

# DB env vars (flat layout: $SSIGN_DB/<db>). Only the ones our toolset needs.
export BAKTA_DB="$SSIGN_DB/bakta"
export SSIGN_PLM_EFFECTOR_WEIGHTS="$SSIGN_DB/plm_effector_weights"

# Annotation-tier env: conda envs on PATH + DB locations. Only when ANNOT=1.
if [ "$ANNOT" = "1" ]; then
    export PATH="$IPS_DIR:$HOME/.conda/envs/eggnog/bin:$HOME/.conda/envs/hhsuite/bin:$PATH"
    export SSIGN_INTERPROSCAN_PATH="$IPS_DIR"
    export EGGNOG_DATA_DIR="$EGGNOG_DIR"
    export SSIGN_ECOD70_DB="$ECOD70_DB"
    export SSIGN_PLMBLAST_SCRIPT="$PLMBLAST_SCRIPT"
    echo "  annotation DBs: IPS=$IPS_DIR  EGGNOG=$EGGNOG_DIR  ECOD70=$ECOD70_DB"
    test -x "$IPS_DIR/interproscan.sh" || echo "WARN: interproscan.sh not at $IPS_DIR"
    test -d "$EGGNOG_DIR"              || echo "WARN: EggNOG data dir missing: $EGGNOG_DIR"
    test -d "$ECOD70_DB"               || echo "WARN: ECOD70 dir missing: $ECOD70_DB"
    test -f "$PLMBLAST_SCRIPT"         || echo "WARN: pLM-BLAST script missing: $PLMBLAST_SCRIPT"
fi

# Pre-flight: local predictors + DeepSecE checkpoint must exist (offline node can't fetch).
SIGNALP_PATH="$HOME/.conda/envs/signalp6/bin"
DEEPLOCPRO_PATH="$HOME/.conda/envs/deeplocpro/bin"
test -x "$SIGNALP_PATH/signalp6"     || echo "WARN: signalp6 not at $SIGNALP_PATH (will fall back to remote, may fail offline)"
test -x "$DEEPLOCPRO_PATH/deeplocpro" || echo "WARN: deeplocpro not at $DEEPLOCPRO_PATH (will fall back to remote, may fail offline)"
test -f "$HOME/.ssign/models/deepsece_checkpoint.pt" || echo "WARN: DeepSecE checkpoint missing at ~/.ssign/models/ (offline node can't download it)"

for u in "${UNITS[@]}"; do
    test -f "$IN_DIR/$u.$IN_EXT" || { echo "FATAL: input not found: $IN_DIR/$u.$IN_EXT"; exit 1; }
done

FAILED=()
for u in "${UNITS[@]}"; do
    in="$IN_DIR/$u.$IN_EXT"
    run_dir="$RUN_ROOT/$u"
    mkdir -p "$run_dir/results"
    echo "---------------------------------------------------------------"
    echo "===== GENOME: $u — START $(date -Is) ====="
    if ssign run "$in" \
            --outdir "$run_dir/results" \
            --tier extended \
            --excluded-systems $EXCLUDED \
            "${MODE_FLAGS[@]}" \
            --signalp-mode local   --signalp-path "$SIGNALP_PATH" \
            --deeplocpro-mode local --deeplocpro-path "$DEEPLOCPRO_PATH" \
            "${EXTRA_FLAGS[@]}" \
            2>&1 | tee "$run_dir/ssign.run.log"; then
        echo "===== GENOME: $u — OK $(date -Is) ====="
    else
        rc=${PIPESTATUS[0]}
        echo "===== GENOME: $u — FAILED (rc=$rc) $(date -Is) ====="
        FAILED+=("$u")
    fi
done

echo
echo "===== BENCHMARK BATCH END $(date -Is) ====="
echo "Output root: $RUN_ROOT"
if [ "${#FAILED[@]}" -eq 0 ]; then
    echo "All ${#UNITS[@]} genomes succeeded."
    exit 0
fi
echo "Failures (${#FAILED[@]}/${#UNITS[@]}): ${FAILED[*]}"
exit 1
