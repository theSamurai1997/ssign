# Heavy / regenerable data — kept out of git (fetch or rebuild locally).
# refseq_cache: ~780 MB of cached RefSeq GenBank genomes (09_fetch_refseq.py repopulates).
data/refseq_cache/
# phase2/runs: ~180 MB of full ssign run outputs per panel genome (regenerate on CX3).
data/phase2/runs/
# external_dbs: ~20 MB of downloaded SecReT4/6 dumps (see data/external_dbs/MANIFEST.md).
data/external_dbs/
# gene_order_index: 19 MB derived index (18_build_gene_order.py rebuilds from refseq_cache).
data/phase1/gene_order_index.tsv

# Staged pipeline inputs + stray genome flat files (regenerable by 22_stage_inputs.py).
# Bare `inputs/` matches at any depth (benchmark/inputs/ and data/**/inputs/).
inputs/
*.gb
*.gbff

__pycache__/
*.pyc
