# .dockerignore — keeps the build context small.
#
# The Dockerfile only COPYs pyproject.toml, README.md, LICENSE, src/, scripts/.
# Everything else listed here is excluded from the build context entirely so
# `docker build` doesn't ship gigabytes of test output, fetched databases,
# or git history to the daemon.

# Version control
.git/
.gitignore
.github/

# Python build artefacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Claude Code working directory + project memory
.claude/
CLAUDE.md
.drafts/

# Local fetched databases / models (may be huge)
.ssign/
data/
models/

# Pipeline run output
results/
ssign_results/
*_progress.json
macsyfinder_out/
emappertmp_*/

# Test fixtures (the Docker image runs against user inputs; no need to ship test data)
tests/

# Documentation source (rendered separately on ReadTheDocs; not needed in the image)
docs/

# Paper artefacts (figures, analysis scripts, Colab notebooks)
figures/
colab/

# Deprecated Nextflow remnants (Plan A.2)
bin/
conf/
.nextflow*

# Skeleton container directory itself — Dockerfile lives here but we don't
# need to ship its README / sibling Dockerfiles into the build context.
containers/

# Local lockfiles + env captures from earlier phases (not in .gitignore
# because Phase 8 release will track uv.lock — exclude here so an old
# baseline doesn't sneak into the image)
requirements-baseline.txt
env_signalp6.lock.txt
uv.lock

# Large binary blobs that shouldn't end up in the build context if a
# user accidentally drops them in the repo root
*.sif
*.tar.gz
*.log
