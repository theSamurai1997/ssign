/*
 * PBS scheduler profile (e.g., Imperial College HPC).
 *
 * Uses Singularity for containers.
 * GPU nodes: Quadro RTX 6000 (24GB) and A40 (48GB).
 */

singularity {
    enabled    = true
    autoMounts = true
}

docker {
    enabled = false
}

process {
    executor = 'pbs'

    // PBS-specific queue/resource syntax
    clusterOptions = { "-l select=1:ncpus=${task.cpus}:mem=${task.memory.toGiga()}gb" }

    withLabel: 'process_gpu' {
        clusterOptions = { "-l select=1:ncpus=${task.cpus}:mem=${task.memory.toGiga()}gb:ngpus=1" }
        queue = 'gpu'
    }
}
