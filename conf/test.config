/*
 * Test profile — lightweight CI run with small test genomes.
 *
 * Skips heavy tools (structure prediction, HH-suite, pLM-BLAST).
 * Uses the two bundled test genomes:
 *   - Xanthobacter tagetidis TagT2C (4461 CDS, 44 contigs)
 *   - Roseixanthobacter finlandensis VTT E-85241 (5077 CDS, 42 contigs)
 */

params {
    input   = "${projectDir}/tests/data/test_samplesheet.csv"
    outdir  = "${launchDir}/results_test"

    // Skip heavy annotation tools for speed
    skip_structure    = true
    skip_foldseek     = true
    skip_hhsuite      = true
    skip_plmblast     = true
    skip_blastp       = true
    skip_interproscan = true

    // Keep lightweight tools
    skip_protparam    = false

    // Resource limits for CI
    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '2.h'
}
