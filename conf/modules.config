/*
 * Per-process output publishing configuration.
 *
 * Controls where each process publishes its output files
 * within params.outdir.
 */

process {
    // Phase 1: Input Processing
    withName: 'DETECT_FORMAT' {
        publishDir = [
            path: { "${params.outdir}/input_processing" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('VERSIONS') ? null : filename }
        ]
    }
    withName: 'PRODIGAL' {
        publishDir = [
            path: { "${params.outdir}/input_processing/prodigal" },
            mode: 'copy'
        ]
    }
    withName: 'BAKTA' {
        publishDir = [
            path: { "${params.outdir}/input_processing/bakta" },
            mode: 'copy'
        ]
    }
    withName: 'EXTRACT_PROTEINS' {
        publishDir = [
            path: { "${params.outdir}/input_processing/proteins" },
            mode: 'copy'
        ]
    }

    // Phase 2: SS Detection
    withName: 'MACSYFINDER' {
        publishDir = [
            path: { "${params.outdir}/ss_detection/macsyfinder" },
            mode: 'copy'
        ]
    }
    withName: 'VALIDATE_SYSTEMS' {
        publishDir = [
            path: { "${params.outdir}/ss_detection" },
            mode: 'copy'
        ]
    }

    // Phase 3: Prediction
    withName: 'DEEPLOCPRO' {
        publishDir = [
            path: { "${params.outdir}/predictions/deeplocpro" },
            mode: 'copy'
        ]
    }
    withName: 'DEEPSECE' {
        publishDir = [
            path: { "${params.outdir}/predictions/deepsece" },
            mode: 'copy'
        ]
    }
    withName: 'SIGNALP' {
        publishDir = [
            path: { "${params.outdir}/predictions/signalp" },
            mode: 'copy'
        ]
    }

    // Phase 4: Substrate ID
    withName: 'PROXIMITY_ANALYSIS' {
        publishDir = [
            path: { "${params.outdir}/substrate_identification" },
            mode: 'copy'
        ]
    }
    withName: 'T5SS_HANDLER' {
        publishDir = [
            path: { "${params.outdir}/substrate_identification/t5ss" },
            mode: 'copy'
        ]
    }
    withName: 'ENRICHMENT_TESTING' {
        publishDir = [
            path: { "${params.outdir}/substrate_identification/enrichment" },
            mode: 'copy'
        ]
    }

    // Phase 5: Annotation
    withName: 'BLASTP_.*' {
        publishDir = [
            path: { "${params.outdir}/annotations/blastp" },
            mode: 'copy'
        ]
    }
    withName: 'HHSUITE_.*' {
        publishDir = [
            path: { "${params.outdir}/annotations/hhsuite" },
            mode: 'copy'
        ]
    }
    withName: 'FOLDSEEK.*' {
        publishDir = [
            path: { "${params.outdir}/annotations/foldseek" },
            mode: 'copy'
        ]
    }
    withName: 'INTERPROSCAN.*' {
        publishDir = [
            path: { "${params.outdir}/annotations/interproscan" },
            mode: 'copy'
        ]
    }
    withName: 'PROTPARAM' {
        publishDir = [
            path: { "${params.outdir}/annotations/protparam" },
            mode: 'copy'
        ]
    }

    // Phase 6: Integration & Reporting
    withName: 'INTEGRATE_ANNOTATIONS' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: 'copy'
        ]
    }
    withName: 'GENERATE_REPORT' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: 'copy'
        ]
    }
    withName: 'GENERATE_FIGURES' {
        publishDir = [
            path: { "${params.outdir}/figures" },
            mode: 'copy'
        ]
    }
}
